# Shared auth secret used by auth_service and dispatcher
SECRET_KEY=yazlab-secret-key

# Internal service URLs consumed by dispatcher
AUTH_SERVICE_URL=http://auth_service:8000
PRODUCT_SERVICE_URL=http://product_service:8000
ORDER_SERVICE_URL=http://order_service:8000

# Service-specific Mongo connection strings
AUTH_MONGO_URL=mongodb://auth_mongo:27017/auth_db
PRODUCT_MONGO_URL=mongodb://product_mongo:27017/product_db
ORDER_MONGO_URL=mongodb://order_mongo:27017/order_db
DISPATCHER_MONGO_URL=mongodb://dispatcher_mongo:27017/dispatcher_db

# Test-time Mongo connection for auth service tests
TEST_AUTH_MONGO_URL=mongodb://auth_mongo:27017
